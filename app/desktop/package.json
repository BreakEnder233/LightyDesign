{
    "name": "lightydesign-desktop",
    "private": true,
    "version": "0.1.3",
    "description": "LightyDesign desktop shell built with Electron and Vite",
    "author": "BreakEnder233",
    "homepage": "https://github.com/BreakEnder233/LightyDesign/releases/latest",
    "repository": {
        "type": "git",
        "url": "https://github.com/BreakEnder233/LightyDesign.git"
    },
    "lightyDesign": {
        "updates": {
            "githubRepository": "https://github.com/BreakEnder233/LightyDesign.git",
            "releasesApiUrl": null,
            "releasesPageUrl": null
        }
    },
    "build": {
        "appId": "com.breakender233.lightydesign",
        "productName": "LightyDesign",
        "asar": true,
        "electronDist": "node_modules/electron/dist",
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "build-resources/desktop-host",
                "to": "desktop-host"
            }
        ],
        "artifactName": "LightyDesign-${version}-${arch}-setup.${ext}",
        "publish": [
            {
                "provider": "github",
                "owner": "BreakEnder233",
                "repo": "LightyDesign"
            }
        ],
        "directories": {
            "output": "dist-installer"
        },
        "win": {
            "executableName": "electron",
            "signAndEditExecutable": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "LightyDesign",
            "deleteAppDataOnUninstall": false
        }
    },
    "type": "module",
    "main": "dist-electron/electron/main.js",
    "scripts": {
        "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
        "dev:renderer": "vite",
        "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
        "build": "npm run build:renderer && npm run build:electron",
        "build:renderer": "vite build",
        "build:electron": "tsc -p tsconfig.electron.json && node ./electron/copy-preload.mjs",
        "dist:win": "electron-builder --win nsis --publish never",
        "preview": "vite preview",
        "start": "electron ."
    },
    "dependencies": {
        "@tanstack/react-virtual": "^3.13.21",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@types/node": "^25.3.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.8.0",
        "electron-builder": "^26.0.12",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "wait-on": "^9.0.4"
    }
}